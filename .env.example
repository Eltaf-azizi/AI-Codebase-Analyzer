# GEMINI_API_KEY: Required for server-side Gemini AI calls.
# This key is loaded on the backend and is not exposed to the browser.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, or deployment metadata.
APP_URL="MY_APP_URL"
